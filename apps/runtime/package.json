{
  "name": "@polar/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "init": "tsx src/cli.ts init",
    "doctor": "tsx src/cli.ts doctor",
    "skill:install": "tsx src/cli.ts skill:install",
    "skill:list": "tsx src/cli.ts skill:list",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@polar/core": "workspace:*",
    "@types/node": "^25.2.0",
    "async-mutex": "^0.5.0",
    "fastify": "^4.29.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "vitest": "^2.1.3"
  }
}