{
  "name": "@polar/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "init": "tsx src/cli.ts init",
    "doctor": "tsx src/cli.ts doctor",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@polar/core": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
